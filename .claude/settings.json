{
  "permissions": {
    "allow": [
      "Bash(npm test)",
      "Bash(npm run check)",
      "Bash(npm run lint)",
      "Bash(npm run format:check)",
      "Bash(npx playwright test:*)",
      "Bash(npx eslint:*)",
      "Bash(npx prettier --check:*)",
      "Bash(node --check:*)",
      "Bash(node .github/scripts/check-inline-js.js)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && (npm ci --silent 2>/dev/null || npm install --silent) >/dev/null 2>&1 || true"
          }
        ]
      }
    ]
  }
}
